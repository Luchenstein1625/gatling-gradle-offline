# Compilados y temporales
.gradle/
**/.gradle/
**/build/
**/bin/
*.class
*.jar
*.war
*.log
*.tmp
*.bak

# Herramientas y datos de análisis: nunca se suben al repositorio.
security-runner/
dependency-check-data/
**/dependency-check-data/
trivy-cache/
**/trivy-cache/
.trivycache/

# Reportes históricos o auxiliares. Solo se versiona el último reporte local.
security-reports/*
!security-reports/latest-vulnerability-report.txt
trivy-*.json
trivy-*.txt
trivy-*.sarif
dependency-check-report.*

# El caché funcional offline de Gradle/Gatling sigue siendo parte del proyecto.
!offline-deps/
!offline-deps/**

data/security/database/odc.mv.db

data/security/database/
data/executions/