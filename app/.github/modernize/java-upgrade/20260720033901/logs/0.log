              "vulVersions": ">= 9.0.0, < 9.0.81",
              "patchedVersion": "9.0.81"
            },
            {
              "name": "org.apache.tomcat.embed:tomcat-embed-core",
              "vulVersions": ">= 8.5.0, < 8.5.94",
              "patchedVersion": "8.5.94"
            },
            {
              "name": "github.com/apple/swift-nio-http2",
              "vulVersions": "< 1.28.0",
              "patchedVersion": "1.28.0"
